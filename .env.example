# Synoptica — environment variables (TEMPLATE)
# Copy to .env for local dev (vercel dev), or set these in Vercel:
# Settings → Environment Variables. NEVER commit your real .env or key.

# Required: your Anthropic API key (server-side only; never reaches the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional tuning (defaults in code are fine)
MAX_SEARCHES=8
RATE_PER_HOUR=20
CACHE_TTL_SECS=21600

# Optional: durable cache + rate limiting + consistent daily trending.
# Add an Upstash Redis database and paste its REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
